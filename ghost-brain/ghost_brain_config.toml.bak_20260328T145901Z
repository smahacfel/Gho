# Modulation range (added to min when tcf_score = 1)
# Value of 0.4 means full momentum preserved when tcf_score = 1.0
tcf_modulation_range = 0.4

# Decay factor for cohesion history integral (0.5-0.99)
# Higher = faster forgetting of old cohesions, faster adaptation
# Lower = longer memory, more stable but slower to detect changes
